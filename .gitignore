# Byte-compiled / caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# Editors / IDE
.idea/
.vscode/
*.swp
*~

# Jupyter
.ipynb_checkpoints/

# OS / Drive cruft
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# Pipeline-generated outputs — regenerated by scripts/phase0*.py.
# The directory skeleton is kept via .gitkeep; the contents are not tracked.
# ---------------------------------------------------------------------------
/outputs/data/*
/outputs/figures/*
/outputs/diagnostics/*
/outputs/tables/*
!**/.gitkeep

# Transient LAMMPS run artifacts (should never be produced by this repo)
log.lammps
*.lmp_log
ffield.reax
